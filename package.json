{
  "name": "@kolkov/ngx-dadata",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve ngx-dadata-app",
    "build": "ng build ngx-dadata-app --configuration production",
    "build:lib": "ng build ngx-dadata --configuration production",
    "build-watch:lib": "ng build ngx-dadata --watch",
    "test:lib": "ng test ngx-dadata",
    "test-ci": "ng test ngx-dadata --coverage",
    "lint:lib": "ng lint ngx-dadata",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "publish:lib": "npm run copy:readme && npm run copy:changelog && npm run copy:license && npm publish ./dist/ngx-dadata",
    "copy:readme": "cpx ./README.md dist/ngx-dadata",
    "copy:changelog": "cpx ./CHANGELOG.md dist/ngx-dadata",
    "copy:license": "cpx ./LICENSE dist/ngx-dadata"
  },
  "dependencies": {
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/elements": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/router": "^22.0.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "cpx": "^1.5.0",
    "eslint": "^10.5.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.8"
  }
}
